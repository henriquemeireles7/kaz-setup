# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — App will not start without these
# ═══════════════════════════════════════════════════════════════════════════════

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/douala

# Auth (better-auth) — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-in-production-min-32-chars

# App
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000

# Payments: Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_MONTHLY_PRICE_ID=price_xxx
PUBLIC_STRIPE_KEY=pk_test_xxx

# Email: Resend
RESEND_API_KEY=re_xxx

# AI: Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Features degrade gracefully without these
# ═══════════════════════════════════════════════════════════════════════════════

# Analytics: PostHog — without this, analytics calls are no-ops
# POSTHOG_API_KEY=phc_xxx
# POSTHOG_HOST=https://us.i.posthog.com
# PUBLIC_POSTHOG_KEY=phc_xxx

# Storage: S3/R2 — without this, file upload/download is unavailable
# R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_BUCKET_NAME=my-bucket

# OAuth: Google — without this, only email/password auth is available
# GOOGLE_CLIENT_ID=xxx
# GOOGLE_CLIENT_SECRET=xxx

# Error Tracking: Sentry — without this, errors are logged but not tracked
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
