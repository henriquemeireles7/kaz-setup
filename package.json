{
  "name": "my-app",
  "version": "0.0.1",
  "type": "module",
  "main": "platform/server/app.ts",
  "scripts": {
    "dev": "bun --hot platform/server/app.ts",
    "build": "bun build platform/server/app.ts --outdir dist --target bun --minify --external=isomorphic-dompurify",
    "start": "bun run dist/app.js",
    "check": "bunx biome ci . && bunx tsc --noEmit && bun run harden && bun test",
    "harden": "bun platform/scripts/harden-check.ts",
    "test": "bun test",
    "lint": "bunx biome check --write --unsafe .",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun platform/scripts/migrate.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/zod-validator": "^0.5.0",
    "@t3-oss/env-core": "^0.12.0",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.38.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.0",
    "isomorphic-dompurify": "^2.20.0",
    "marked": "^15.0.0",
    "posthog-node": "^4.4.0",
    "postgres": "^3.4.0",
    "preact": "^10.25.0",
    "preact-render-to-string": "^6.5.0",
    "resend": "^4.1.0",
    "stripe": "^17.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
